pipeline {
    agent any
    
    environment {
        PYTHON_VERSION = '3.9'
        VENV_DIR = 'venv'
        ALLURE_RESULTS = 'reports/allure-results'
        ALLURE_REPORT = 'reports/allure-html'
    }
    
    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timestamps()
        ansiColor('xterm')
    }
    
    stages {
        stage('Checkout') {
            steps {
                cleanWs()
                checkout scm
            }
        }
        
        stage('Setup Python Environment') {
            steps {
                sh '''
                    python3 -m venv ${VENV_DIR}
                    . ${VENV_DIR}/bin/activate
                    pip install --upgrade pip
                    pip install -r requirements.txt
                '''
            }
        }
        
        // Run ONLY auto_run_full_flow.py (E2E standalone script)
        stage('Run E2E Flow') {
            steps {
                sh '''
                    . ${VENV_DIR}/bin/activate
                    mkdir -p ${ALLURE_RESULTS}
                    
                    # Run ONLY auto_run_full_flow.py with Allure enabled
                    # Option 2 = Auto-generate mobile number
                    echo "2" | python auto_run_full_flow.py --allure --allure-dir ${ALLURE_RESULTS}
                '''
            }
        }
        
        stage('Add Environment Info') {
            steps {
                sh '''
                    cat > ${ALLURE_RESULTS}/environment.properties << EOF
Environment=JENKINS
Browser=API
Platform=Linux
Python.Version=${PYTHON_VERSION}
Test.Framework=Standalone
Test.Runner=Allure
Report.Version=2.15.3
Build.Number=${BUILD_NUMBER}
Build.Id=${BUILD_ID}
Job.Name=${JOB_NAME}
EOF
                '''
            }
        }
        
        stage('Generate Allure Report') {
            steps {
                script {
                    allure([
                        includeProperties: false,
                        jdk: '',
                        properties: [],
                        reportBuildPolicy: 'ALWAYS',
                        results: [[path: "${ALLURE_RESULTS}"]]
                    ])
                }
            }
        }
    }
    
    post {
        always {
            archiveArtifacts artifacts: 'reports/**/*', allowEmptyArchive: true
        }
        
        success {
            echo '✅ E2E Flow Complete! Allure Report Generated.'
        }
        
        failure {
            echo '❌ E2E Flow Failed! Check Allure report for details.'
        }
    }
}
